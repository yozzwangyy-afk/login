# =========================================
# SERVER
# =========================================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# =========================================
# DATABASE (MongoDB Atlas / lokal)
# =========================================
MONGO_URI=mongodb://127.0.0.1:27017/auth_system

# =========================================
# JWT & ENKRIPSI
# =========================================
JWT_ACCESS_SECRET=ganti_dengan_string_acak_panjang_1
JWT_REFRESH_SECRET=ganti_dengan_string_acak_panjang_2
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
TOKEN_ENCRYPTION_KEY=ganti_dengan_string_acak_32_karakter

# =========================================
# GOOGLE OAUTH
# (Dibuat di https://console.cloud.google.com/apis/credentials)
# =========================================
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx

# =========================================
# FACEBOOK LOGIN
# (Dibuat di https://developers.facebook.com/apps)
# =========================================
FACEBOOK_APP_ID=xxxxxxxx
FACEBOOK_APP_SECRET=xxxxxxxx

# =========================================
# APPLE SIGN IN
# (Dibuat di https://developer.apple.com/account/resources/identifiers/list)
# =========================================
APPLE_CLIENT_ID=com.yourcompany.yourapp
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
# Isi dengan private key .p8 (ganti baris baru dengan \n jika disimpan sebagai 1 baris)
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----"
